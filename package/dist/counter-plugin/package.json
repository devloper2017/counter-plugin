{
  "name": "@nawazaideveloperr/counter-plugin",
  "version": "0.0.5",
  "description": "A lightweight animated counter plugin for Angular, React, and Vanilla JS.",
  "author": "Nawaz",
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": "^19.2.0",
    "@angular/core": "^19.2.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false,
  "keywords": [
    "angular counter",
    "react counter",
    "animated counter",
    "typescript counter plugin",
    "npm counter library",
    "vanilla js counter",
    "frontend utility",
    "cross framework plugin"
  ],
  "module": "fesm2022/nawazaideveloperr-counter-plugin.mjs",
  "typings": "index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./index.d.ts",
      "default": "./fesm2022/nawazaideveloperr-counter-plugin.mjs"
    }
  }
